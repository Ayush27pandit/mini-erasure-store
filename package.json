{
  "name": "mini-erasure-store",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "storage-node": "tsx src/storage-node/index.ts",
    "start:nodes": "for i in $(seq 1 6); do PORT=$((3000 + i)) tsx src/storage-node/index.ts --port=$((3000 + i)) --node=node_$i & sleep 0.5; done; wait",
    "start:all": "npm run start:nodes & sleep 2 && npm start"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@digitaldefiance/reed-solomon-erasure.wasm": "^1.0.2",
    "express": "^5.2.1",
    "multer": "^2.2.0",
    "typescript": "^6.0.3",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^26.1.0",
    "tsx": "^4.22.4"
  }
}
